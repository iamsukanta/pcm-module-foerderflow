# --- App ---
ENVIRONMENT=development
DEBUG=true

# --- Database (SQLAlchemy 2 + psycopg3). Use host 'db' inside docker-compose. ---
DATABASE_URL=postgresql+psycopg://foerderflow:password@localhost:5432/foerderflow

# --- Auth (magic-link -> JWT) ---
AUTH_SECRET=change-me-run-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_MINUTES=1440

# --- Frontend / CORS ---
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# --- Email (magic link). Mailpit for dev; IONOS SMTP for prod. ---
EMAIL_SERVER_HOST=mailpit
EMAIL_SERVER_PORT=1025
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=FörderFlow <noreply@foerderflow.local>

# --- Bescheid OCR (Mistral). Optional — empty disables PDF import. ---
MISTRAL_API_KEY=
