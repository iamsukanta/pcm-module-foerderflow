# ── Root environment for docker-compose ──────────────────────────────
# Copy to .env and fill in. Values cascade into backend + frontend containers.

# Database
POSTGRES_DB=foerderflow
POSTGRES_USER=foerderflow
POSTGRES_PASSWORD=password

# Ports
BACKEND_PORT=8000
FRONTEND_PORT=3000

# App
ENVIRONMENT=development
DEBUG=true

# Auth (generate: openssl rand -hex 32)
AUTH_SECRET=change-me-run-openssl-rand-hex-32

# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000/api
BACKEND_INTERNAL_URL=http://backend:8000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (magic link). Dev = mailpit. Prod = real SMTP (e.g. IONOS).
EMAIL_SERVER_HOST=mailpit
EMAIL_SERVER_PORT=1025
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=FörderFlow <noreply@foerderflow.local>

# Bescheid OCR (Mistral) — optional; leave empty to disable PDF import.
MISTRAL_API_KEY=

# Seed demo data on backend startup (1 = yes)
RUN_SEED=0
